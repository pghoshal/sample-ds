      "reason": "Provides the public DataTable implementation."
    }
  ],
  "importGuidance": {
    "named": ["DataTable"],
    "sideEffects": [],
    "notes": ["Use DataTable for sortable records; provide ariaLabel and explicit columns."]
  },
  "platforms": [
    {
      "platform": "web",
      "framework": "react",
      "package": "@atlas/ui",
      "importPath": "@atlas/ui/data-table",
      "component": "DataTable",
      "tokens": {
        "surface": "token:color.surface.raised",
        "headerSurface": "token:color.surface.muted",
        "stickyLayer": "token:layer.sticky",
        "compactHeight": "token:density.compact.control.height",
        "focusRing": "token:state.action.primary.focusRing"
      },
      "props": {
        "density": "compact",
        "sortable": true
      },
      "notes": ["Use density=\"compact\" only for data-heavy operational pages."]
    }
  ],
  "status": "stable",
  "tags": ["data", "table", "billing", "risk"],
  "props": [
    {
      "name": "ariaLabel",
      "type": "string",
      "required": true,
      "description": "Accessible table label."
    },
    {
      "name": "density",
      "type": "\"compact\" | \"comfortable\"",
