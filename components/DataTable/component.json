      "values": ["compact", "comfortable"],
      "description": "Row density."
    },
    {
      "name": "sortable",
      "type": "boolean",
      "required": false,
      "default": true,
      "description": "Whether column headers expose sort controls."
    }
  ],
  "examples": [
    {
      "name": "Invoice risk table",
      "language": "tsx",
      "code": "import { DataTable } from \"@atlas/ui/data-table\";\n\n<DataTable ariaLabel=\"Invoice risk records\" density=\"compact\" sortable />"
    }
  ],
  "constraints": [
    {
      "id": "table-accessible-label",
      "severity": "error",
      "message": "DataTable requires an ariaLabel that names the record set."
    }
  ],
