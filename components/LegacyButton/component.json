      "Map intent=\"danger\" to variant=\"danger\".",
      "Replace token:color.action.legacyPrimary with token:color.action.primary."
    ],
    "examples": [
      {
        "name": "LegacyButton to Button",
        "language": "tsx",
        "code": "<Button variant=\"danger\">Suspend account</Button>"
      }
    ]
  },
