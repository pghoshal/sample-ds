    {
      "name": "theme",
      "type": "\"light\" | \"dark\" | \"highContrast\"",
      "required": true,
      "values": ["light", "dark", "highContrast"],
      "description": "Active visual theme."
    },
    {
      "name": "density",
      "type": "\"compact\" | \"comfortable\"",
      "required": true,
      "values": ["compact", "comfortable"],
      "description": "Active layout density."
    }
  ],
  "examples": [
    {
      "name": "Light comfortable app shell",
      "language": "tsx",
      "code": "import { ThemeProvider } from \"@atlas/ui/theme-provider\";\n\n<ThemeProvider theme=\"light\" density=\"comfortable\">...</ThemeProvider>"
    }
  ],
